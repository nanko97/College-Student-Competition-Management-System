' ==this.flag && this.ruleForm.youxiang&&(!isEmail(this.ruleForm.youxiang))){\n        this.$message.error(`邮箱应输入邮箱格式`);\n        return\n      }\n      if('users'==this.flag && this.ruleForm.username.trim().length<1) {\n\tthis.$message.error(`用户名不能为空`);\n        return\t\n      }\n      this.$http({\n        url: `${this.$storage.get(\"sessionTable\")}/update`,\n        method: \"post\",\n        data: this.ruleForm\n      }).then(({ data }) => {\n        if (data && data.code === 0) {\n          this.$message({\n            message: \"修改信息成功\",\n            type: \"success\",\n            duration: 1500,\n            onClose: () => {\n            }\n          });\n        } else {\n          this.$message.error(data.msg);\n        }\n      });\n    }\n  }\n};\n</script>\n<style lang=\"scss\" scoped>\n</style>\n"],"mappings":"AA0IA;AACA,SAAAA,QAAA,EAAAC,UAAA,EAAAC,OAAA,EAAAC,QAAA,EAAAC,OAAA,EAAAC,KAAA,EAAAC,WAAA;AAEA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,IAAA;MACAC,SAAA;MACAC,sBAAA;MACAC,oBAAA;MACAC,qBAAA;IACA;EACA;EACAC,QAAA;IACA,IAAAC,KAAA,QAAAC,QAAA,CAAAC,GAAA;IACA,KAAAR,IAAA,GAAAM,KAAA;IACA,KAAAG,KAAA;MACAC,GAAA,UAAAH,QAAA,CAAAC,GAAA;MACAG,MAAA;IACA,GAAAC,IAAA;MAAAd;IAAA;MACA,IAAAA,IAAA,IAAAA,IAAA,CAAAe,IAAA;QACA,KAAAd,QAAA,GAAAD,IAAA,CAAAA,IAAA;MACA;QACA,KAAAgB,QAAA,CAAAC,KAAA,CAAAjB,IAAA,CAAAkB,GAAA;MACA;IACA;IACA,KAAAd,sBAAA,SAAAe,KAAA;IACA,KAAAb,qBAAA,SAAAa,KAAA;EACA;EACAC,OAAA;IACAC,6BAAAC,QAAA;MACA,KAAArB,QAAA,CAAAsB,QAAA,GAAAD,QAAA;IACA;IACAE,4BAAAF,QAAA;MACA,KAAArB,QAAA,CAAAsB,QAAA,GAAAD,QAAA;IACA;IACAG,gBAAA;MACA,UAAAxB,QAAA,CAAAyB,MAAA,uBAAAxB,IAAA;QACA,KAAAc,QAAA,CAAAC,KAAA;QACA;MACA;MACA,UAAAhB,QAAA,CAAA0B,IAAA,uBAAAzB,IAAA;QACA,KAAAc,QAAA,CAAAC,KAAA;QACA;MACA;MACA,UAAAhB,QAAA,CAAA2B,gBAAA,uBAAA1B,IAAA;QACA,KAAAc,QAAA,CAAAC,KAAA;QACA;MACA;MACA,uBAAAf,IAAA,SAAAD,QAAA,CAAA4B,MAAA,KAAAjC,QAAA,MAAAK,QAAA,CAAA4B,MAAA;QACA,KAAAb,QAAA,CAAAC,KAAA;QACA;MACA;MACA,uBAAAf,IAAA,SAAAD,QAAA,CAAA6B,QAAA,KAAAnC,OAAA,MAAAM,QAAA,CAAA6B,QAAA;QACA,KAAAd,QAAA,CAAAC,KAAA;QACA;